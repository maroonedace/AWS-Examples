#!/usr/bin/env bash

QUEUE_URL="https://sqs.us-west-2.amazonaws.com/123456789012/MyQueue"

aws sqs send-message \ 
--queue-url $QUEUE_URL \
--message-body "Information" \
--message-group-id "hello" \
--message-deduplication-id "1"
--message-attributes file://send-message.json

aws sqs send-message \ 
--queue-url $QUEUE_URL \
--message-body "Information 2" \
--message-group-id "hello" \
--message-deduplication-id "2" \
--message-attributes file://send-message.json